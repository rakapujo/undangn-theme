<?xml version="1.0"?>
<ruleset name="Undangan Theme">
    <description>WordPress Coding Standards untuk theme Undangan</description>

    <!-- Path yang di-scan -->
    <file>inc/</file>
    <file>functions.php</file>
    <file>index.php</file>

    <!-- Yang di-exclude -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>

    <!-- Argumen CLI -->
    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Standar dasar -->
    <rule ref="WordPress-Extra">
        <!-- PSR-4: nama file class boleh PascalCase -->
        <exclude name="WordPress.Files.FileName"/>
        <!-- camelCase method dalam class (CLAUDE.md Bagian 4) -->
        <exclude name="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.PropertyNotSnakeCase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedVariableNotSnakeCase"/>
        <!-- Prefix mgu/MGU sengaja dipilih singkat (3 char) sesuai CLAUDE.md Bagian 4.1.
             WPCS standar minta minimum 4 char, kita override karena:
             - Namespace PSR-4 Mengundang\Theme\ sudah jadi proteksi utama
             - REST namespace mengundang/v1 sudah unik
             - mgu_ jelas merujuk ke "mengundang" -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.ShortPrefixPassed"/>
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedConstantFound"/>
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>
    </rule>
    <rule ref="WordPress-Docs"/>

    <!-- Text domain wajib -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="undangan"/>
            </property>
        </properties>
    </rule>

    <!-- Prefix wajib mgu_ untuk hook/filter/option/global function -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="mgu"/>
                <element value="MGU"/>
                <element value="Mgu"/>
                <element value="Mengundang\Theme"/>
            </property>
        </properties>
    </rule>

    <!-- PHP 8.3 minimum -->
    <config name="testVersion" value="8.3-"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- WP version target -->
    <config name="minimum_supported_wp_version" value="6.5"/>
</ruleset>
