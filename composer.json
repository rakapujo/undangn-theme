{
    "name": "mengundang/undangan-theme",
    "description": "SaaS undangan digital — block theme dengan custom routing subdomain *.mengundang.mu",
    "type": "wordpress-theme",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "Mengundang\\Theme\\": "inc/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mengundang\\Theme\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint:php": "phpcs",
        "lint:php:fix": "phpcbf",
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
