# Environment
WP_ENV=development
# development | staging | production

# Cloudflare (untuk auto-purge cache saat undangan di-update)
# Buat token di: Cloudflare → My Profile → API Tokens → Custom Token
# Permission: Zone.Cache Purge
# Resource: Specific zone → mengundang.mu
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Domain root SaaS (untuk routing & validasi subdomain)
MGU_ROOT_DOMAIN=mengundang.mu

# Imagick HEIF support (auto-detect, set true kalau imagick mendukung HEIC)
MGU_HEIF_SUPPORT=false
